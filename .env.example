# Copy this file to .env and fill in real local values.
# Never commit .env because it contains API keys and local paths.

# PowerShell / Python IO
PYTHONUTF8=1
PYTHONIOENCODING=utf-8

# Qdrant
BRAIN_ENABLE_LOCAL_RAG=false
REPORT_ENABLE_LOCAL_RAG=false
FULL_REPORT_DEFAULT_ROUTE=web
BRAIN_AGENT_ROUTE=web
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=
QDRANT_PREFER_GRPC=false

# Embedding / rerank
RAG_HF_CACHE_DIR=
RAG_ENABLE_API_RERANK=false
RAG_RERANK_PROVIDER=cohere
RAG_RERANK_URL=
RAG_RERANK_API_KEY=
RAG_RERANK_MODEL=

# LLM profiles
RAG_LLM_PROFILES=qwen,deepseek-v4-pro,deepseek-v4-flash,gpt-5.5,gemini-3.5-flash
RAG_LLM_ACTIVE_PROFILE=qwen
RAG_LLM_EXECUTION_PROFILE=qwen
REPORT_SELECT_LLM_PROFILE=false

RAG_LLM_PROFILE_QWEN_PROVIDER=openai_compatible
RAG_LLM_PROFILE_QWEN_URL=
RAG_LLM_PROFILE_QWEN_API_KEY=
RAG_LLM_PROFILE_QWEN_MODEL=qwen3.6-plus
RAG_LLM_PROFILE_QWEN_TIMEOUT=180
RAG_LLM_PROFILE_QWEN_DISABLE_THINKING=false

RAG_LLM_PROFILE_DEEPSEEK_V4_PRO_PROVIDER=openai_compatible
RAG_LLM_PROFILE_DEEPSEEK_V4_PRO_URL=
RAG_LLM_PROFILE_DEEPSEEK_V4_PRO_API_KEY=
RAG_LLM_PROFILE_DEEPSEEK_V4_PRO_MODEL=deepseek-v4-pro
RAG_LLM_PROFILE_DEEPSEEK_V4_PRO_TIMEOUT=240
RAG_LLM_PROFILE_DEEPSEEK_V4_PRO_DISABLE_THINKING=false

RAG_LLM_PROFILE_DEEPSEEK_V4_FLASH_PROVIDER=openai_compatible
RAG_LLM_PROFILE_DEEPSEEK_V4_FLASH_URL=https://api.deepseek.com/chat/completions
RAG_LLM_PROFILE_DEEPSEEK_V4_FLASH_API_KEY=
RAG_LLM_PROFILE_DEEPSEEK_V4_FLASH_MODEL=deepseek-v4-flash
RAG_LLM_PROFILE_DEEPSEEK_V4_FLASH_TIMEOUT=90
RAG_LLM_PROFILE_DEEPSEEK_V4_FLASH_DISABLE_THINKING=true

RAG_LLM_PROFILE_GPT_5_5_PROVIDER=openai_compatible
RAG_LLM_PROFILE_GPT_5_5_URL=https://api.openai.com/v1/responses
RAG_LLM_PROFILE_GPT_5_5_API_KEY=
RAG_LLM_PROFILE_GPT_5_5_MODEL=gpt-5.5
RAG_LLM_PROFILE_GPT_5_5_TIMEOUT=240
RAG_LLM_PROFILE_GPT_5_5_DISABLE_THINKING=false
RAG_LLM_PROFILE_GPT_5_5_REASONING_EFFORT=high
RAG_LLM_PROFILE_GPT_5_5_MAX_OUTPUT_TOKENS=32000
# If GPT-5.5 is unavailable (for example quota/429), quality tasks automatically retry with this profile.
RAG_LLM_GPT55_FALLBACK_PROFILE=deepseek-v4-pro

RAG_LLM_PROFILE_GEMINI_3_5_FLASH_PROVIDER=openai_compatible
RAG_LLM_PROFILE_GEMINI_3_5_FLASH_URL=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions
RAG_LLM_PROFILE_GEMINI_3_5_FLASH_API_KEY=
RAG_LLM_PROFILE_GEMINI_3_5_FLASH_MODEL=gemini-3.5-flash
RAG_LLM_PROFILE_GEMINI_3_5_FLASH_TIMEOUT=300
RAG_LLM_PROFILE_GEMINI_3_5_FLASH_DISABLE_THINKING=false

# Functional model routing - quality first
# deepseek-v4-flash stays configured as a fast fallback, but is not used by the default quality path.
RAG_MODEL_PLANNING_PROFILE=gpt-5.5
RAG_MODEL_QUERY_REWRITE_PROFILE=deepseek-v4-pro
RAG_MODEL_WEB_SUMMARY_PROFILE=qwen
RAG_MODEL_EVIDENCE_MERGE_PROFILE=deepseek-v4-pro
RAG_MODEL_COVERAGE_EVAL_PROFILE=gpt-5.5
RAG_MODEL_CLAIM_BUILD_PROFILE=qwen
RAG_MODEL_RISK_PROFILE=deepseek-v4-pro
RAG_MODEL_DECISION_PROFILE=gpt-5.5
RAG_MODEL_WRITER_PROFILE=qwen
RAG_MODEL_REFORMATTER_PROFILE=gpt-5.5
RAG_MODEL_QA_PROFILE=gpt-5.5
RAG_MODEL_REFLECTION_PROFILE=gpt-5.5
RAG_MODEL_FINAL_AUDIT_PROFILE=gpt-5.5
RAG_MODEL_MULTIMODAL_LONGDOC_PROFILE=gemini-3.5-flash

# Final audit - enabled by default in quality-first mode
REPORT_ENABLE_FINAL_AUDIT=true
REPORT_FINAL_AUDIT_BLOCKING=true
REPORT_FINAL_AUDIT_MAX_CHARS=200000

# Runtime token monitor - LLM calls only; embedding/rerank/Qdrant are excluded.
RAG_TOKEN_MONITOR_ENABLED=true
RAG_TOKEN_MONITOR_PRINT=true
RAG_TOKEN_MONITOR_PRINT_EACH_CALL=true
RAG_TOKEN_MONITOR_JSONL=true
RAG_TOKEN_MONITOR_JSONL_PATH=
RAG_TOKEN_MONITOR_MAX_EVENTS=10000

# Planner / synthesis / review / reflection explicit configs
RAG_ENABLE_LLM_PLANNER=false
RAG_LLM_PLANNER_PROVIDER=openai_compatible
RAG_LLM_PLANNER_URL=
RAG_LLM_PLANNER_API_KEY=
RAG_LLM_PLANNER_MODEL=
RAG_LLM_PLANNER_TIMEOUT=30

RAG_ENABLE_LLM_SYNTHESIS=true
RAG_LLM_SYNTHESIS_PROVIDER=openai_compatible
RAG_LLM_SYNTHESIS_URL=
RAG_LLM_SYNTHESIS_API_KEY=
RAG_LLM_SYNTHESIS_MODEL=qwen3.6-plus
RAG_LLM_SYNTHESIS_TIMEOUT=180

RAG_ENABLE_LLM_ANSWER_REVIEW=true
RAG_LLM_ANSWER_REVIEW_PROVIDER=openai_compatible
RAG_LLM_ANSWER_REVIEW_URL=
RAG_LLM_ANSWER_REVIEW_API_KEY=
RAG_LLM_ANSWER_REVIEW_MODEL=
RAG_LLM_ANSWER_REVIEW_TIMEOUT=180

RAG_ENABLE_LLM_REFLECTION=true
RAG_LLM_REFLECTION_PROVIDER=openai_compatible
RAG_LLM_REFLECTION_URL=
RAG_LLM_REFLECTION_API_KEY=
RAG_LLM_REFLECTION_MODEL=
RAG_LLM_REFLECTION_TIMEOUT=180

# Aliyun IQS
ALIYUN_IQS_API_KEY=
IQS_SEARCH_TIMEOUT_MS=18000
IQS_MAX_QUERIES=4
IQS_INITIAL_MAX_QUERIES=3
IQS_FOLLOWUP_MAX_QUERIES=3
IQS_MAX_SEARCH_TASKS=12
IQS_INITIAL_MAX_SEARCH_TASKS=12
IQS_FOLLOWUP_MAX_SEARCH_TASKS=8
IQS_RESULTS_PER_QUERY=40
IQS_INITIAL_RESULTS_PER_QUERY=30
IQS_FOLLOWUP_RESULTS_PER_QUERY=30
IQS_ENABLE_BATCH_SEARCH=true
IQS_BATCH_CONCURRENCY=2
IQS_PARALLEL_WORKERS=2
IQS_RERANK_TOP_K=16
IQS_INITIAL_RERANK_TOP_K=12
IQS_FOLLOWUP_RERANK_TOP_K=12
IQS_RERANK_MAX_DOCS=50
IQS_INITIAL_RERANK_MAX_DOCS=40
IQS_FOLLOWUP_RERANK_MAX_DOCS=40
IQS_RERANK_PREFILTER_MAX_DOCS=50
IQS_INITIAL_RERANK_PREFILTER_MAX_DOCS=40
IQS_FOLLOWUP_RERANK_PREFILTER_MAX_DOCS=40
IQS_ENABLE_LLM_QUERY_REWRITE=false
IQS_ENABLE_HYDE=false
IQS_ENABLE_SELF_REFINE=false
IQS_AUTO_READPAGE_TOP_N=3
IQS_AUTO_READPAGE_REQUIRED_TOP_N=4
IQS_AUTO_READPAGE_MIN_SCORE=0.65
IQS_AUTO_READPAGE_REQUIRED_MIN_SCORE=0.45
IQS_READPAGE_TIMEOUT_MS=25000
IQS_READPAGE_PARALLEL_WORKERS=3
FULL_REPORT_IQS_MAX_QUERIES=3
FULL_REPORT_IQS_MAX_SEARCH_TASKS=12
FULL_REPORT_IQS_RESULTS_PER_QUERY=30
FULL_REPORT_IQS_RERANK_TOP_K=12
FULL_REPORT_IQS_RERANK_MAX_DOCS=40
FULL_REPORT_IQS_RERANK_PREFILTER_MAX_DOCS=40
FULL_REPORT_IQS_ENABLE_SELF_REFINE=false
IQS_DEEP_REPAIR_ENABLED=true
IQS_DEEP_REPAIR_MAX_TASKS_PER_ROUND=4
IQS_DEEP_REPAIR_MAX_TASKS_PER_REPORT=14
IQS_DEEP_REPAIR_EVIDENCE_PREFLIGHT_MAX=3
IQS_DEEP_REPAIR_POST_QA_MAX=4
IQS_DEEP_REPAIR_REFORMATTER_PREFLIGHT_MAX=2
IQS_DEEP_REPAIR_LAYOUT_MAX=2
IQS_DEEP_REPAIR_TIMEOUT_MS=45000
IQS_DEEP_REPAIR_NUM_RESULTS=10
IQS_DEEP_REPAIR_FALLBACK_ENGINES=LiteAdvanced,GenericAdvanced,Generic
BRAIN_IQS_INITIAL_LANE_QUALITY_FIRST=true
BRAIN_IQS_INITIAL_LANE_TOP_N=6
BRAIN_IQS_INITIAL_DISABLED_LANES=
BRAIN_IQS_INITIAL_ENABLE_CUSTOMER_CASE=true
BRAIN_IQS_LANE_EARLY_STOP_ENABLED=true
BRAIN_IQS_LANE_EARLY_STOP_MIN_SECONDS=45
BRAIN_IQS_LANE_EARLY_STOP_MIN_COMPLETED_TASKS=2
BRAIN_IQS_LANE_EARLY_STOP_MIN_AB_SOURCES=2
BRAIN_IQS_LANE_EARLY_STOP_MIN_USABLE_SOURCES=5
BRAIN_IQS_LANE_CIRCUIT_BREAKER_ENABLED=true
BRAIN_REPAIR_HIGH_VALUE_SELECTION_ENABLED=true
BRAIN_REPAIR_MAX_TASKS_PER_ROUND=10
BRAIN_POST_QA_REPAIR_MAX_EVIDENCE_TASKS=8
BRAIN_REPAIR_MAX_TASKS_PER_CHAPTER=2
BRAIN_FORCE_DEEP_SEARCH_FOR_INDUSTRY=true
BRAIN_ENABLE_RETRIEVAL_MODE_ROUTING=true
BRAIN_MAX_TASKS_PER_IQS_LANE=32
BRAIN_CONTINUOUS_MAX_TASKS_PER_IQS_LANE=32
BRAIN_WEB_ENABLE_LLM_ANALYSIS=false
BRAIN_ENABLE_LLM_COVERAGE_EVAL=false
BRAIN_SUPERVISOR_MAX_LOOPS=2
BRAIN_SUPERVISOR_MAX_FOLLOWUP_QUERIES=3
BRAIN_FOLLOWUP_MAX_TASKS_PER_ROUND=4
BRAIN_IQS_LANE_PARALLEL_WORKERS=2
BRAIN_IQS_LANE_TASK_TIMEOUT_SECONDS=120
BRAIN_AGENT_TEXT_SELF_REFINE=false
REPORT_CONTINUOUS_EVIDENCE_LOOP=false

# OpenAI Web Search gap repair (enabled as a bounded repair layer; IQS remains primary)
OPENAI_WEB_SEARCH_ENABLED=true
OPENAI_API_KEY=
OPENAI_WEB_SEARCH_MODEL=gpt-5.5
OPENAI_WEB_SEARCH_REASONING_EFFORT=high
OPENAI_WEB_SEARCH_MODE=gap_repair
OPENAI_WEB_SEARCH_ALLOWED_DOMAINS=
OPENAI_WEB_SEARCH_MAX_TASKS_PER_REPORT=30
OPENAI_WEB_SEARCH_MAX_GAP_REPAIR_TASKS_PER_ROUND=6
OPENAI_WEB_SEARCH_HARD_MAX_TASKS_PER_REPORT=36
OPENAI_WEB_SEARCH_CONCURRENCY=2
OPENAI_WEB_SEARCH_MAX_CONSECUTIVE_FAILURES_PER_REPORT=6
OPENAI_WEB_SEARCH_INFER_ALLOWED_DOMAINS=false
OPENAI_WEB_SEARCH_TIMEOUT_SECONDS=180
OPENAI_WEB_SEARCH_EXTERNAL_WEB_ACCESS=true

# Persistent evidence/search cache
EVIDENCE_CACHE_ENABLED=true
EVIDENCE_CACHE_PATH=output/cache/evidence_cache.sqlite
EVIDENCE_CACHE_SQLITE_JOURNAL_MODE=MEMORY
EVIDENCE_CACHE_SEARCH_READ_ENABLED=true
EVIDENCE_CACHE_EVIDENCE_READ_ENABLED=true
EVIDENCE_CACHE_WRITE_ENABLED=true
EVIDENCE_CACHE_MAX_TEXT_CHARS_PER_RESULT=12000
EVIDENCE_CACHE_MAX_HITS_PER_TASK=6
EVIDENCE_CACHE_NEGATIVE_TTL_HOURS=6
TRUSTED_SOURCE_CACHE_ENABLED=true
TRUSTED_SOURCE_CACHE_PATH=output/cache/trusted_sources.jsonl

# Report quality controls
REPORT_QUALITY_MODE=strict
REPORT_PROOF_MODE=deep_industry_report
REPORT_PROGRESS_BAR=true
REPORT_REFORMATTER_SOURCE_APPENDIX=cited
REPORT_REFORMATTER_REQUIRE_SOURCE_APPENDIX=true
REPORT_FINAL_WRITER_SOURCE_APPENDIX=true
REPORT_TARGET_BODY_CHARS=20000
REPORT_TARGET_BODY_CHARS_BLOCKING=true
REPORT_TARGET_CORE_CHAPTER_COUNT=5
REPORT_MAX_CORE_CHAPTER_COUNT=6
REPORT_MIN_CORE_AB_SOURCES_PER_CHAPTER=2
REPORT_KEY_CHAPTER_MIN_TRACEABLE_AB=3
REPORT_MIN_COUNTER_SOURCES_PER_REPORT=2
REPORT_COUNTER_SCOPE=report_level
REPORT_ENABLE_EVIDENCE_PREFLIGHT=true
QA_DEEP_EVALUATOR_BLOCKING=true
QA_MIN_PASS_SCORE=75
QA_DEEP_MIN_DEPTH_SCORE=75
QA_DEEP_BLOCK_DROPPED_TASKS=true
QA_DEEP_BLOCK_LANE_FAILURES=true
QA_DEEP_BLOCK_PROOF_GAPS=true
REPORT_ENABLE_TABLES=true
REPORT_MAX_BODY_TABLES=6
REPORT_MAX_BODY_TABLES_PER_CHAPTER=1
REPORT_MAX_BODY_TABLE_ROWS=6
REPORT_CONTRACT_ENABLED=true
EVIDENCE_LEDGER_ENABLED=true
QUALITY_GATE_STATE_MACHINE_ENABLED=true
QUALITY_GATE_ENFORCE=false
