# Copy this file to .env and fill in real local values.
# Never commit .env because it contains API keys and local paths.

# PowerShell / Python IO
PYTHONUTF8=1
PYTHONIOENCODING=utf-8

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=
QDRANT_PREFER_GRPC=false

# Embedding / rerank
RAG_HF_CACHE_DIR=
RAG_ENABLE_API_RERANK=false
RAG_RERANK_PROVIDER=cohere
RAG_RERANK_URL=
RAG_RERANK_API_KEY=
RAG_RERANK_MODEL=

# LLM profiles
RAG_LLM_PROFILES=qwen,deepseek-v4-pro
RAG_LLM_ACTIVE_PROFILE=qwen
RAG_LLM_EXECUTION_PROFILE=qwen
REPORT_SELECT_LLM_PROFILE=false

RAG_LLM_PROFILE_QWEN_PROVIDER=openai_compatible
RAG_LLM_PROFILE_QWEN_URL=
RAG_LLM_PROFILE_QWEN_API_KEY=
RAG_LLM_PROFILE_QWEN_MODEL=
RAG_LLM_PROFILE_QWEN_TIMEOUT=180
RAG_LLM_PROFILE_QWEN_DISABLE_THINKING=true

RAG_LLM_PROFILE_DEEPSEEK_V4_PRO_PROVIDER=openai_compatible
RAG_LLM_PROFILE_DEEPSEEK_V4_PRO_URL=
RAG_LLM_PROFILE_DEEPSEEK_V4_PRO_API_KEY=
RAG_LLM_PROFILE_DEEPSEEK_V4_PRO_MODEL=
RAG_LLM_PROFILE_DEEPSEEK_V4_PRO_TIMEOUT=240
RAG_LLM_PROFILE_DEEPSEEK_V4_PRO_DISABLE_THINKING=false

# Planner / synthesis / review / reflection explicit configs
RAG_ENABLE_LLM_PLANNER=false
RAG_LLM_PLANNER_PROVIDER=openai_compatible
RAG_LLM_PLANNER_URL=
RAG_LLM_PLANNER_API_KEY=
RAG_LLM_PLANNER_MODEL=
RAG_LLM_PLANNER_TIMEOUT=30

RAG_ENABLE_LLM_SYNTHESIS=true
RAG_LLM_SYNTHESIS_PROVIDER=openai_compatible
RAG_LLM_SYNTHESIS_URL=
RAG_LLM_SYNTHESIS_API_KEY=
RAG_LLM_SYNTHESIS_MODEL=
RAG_LLM_SYNTHESIS_TIMEOUT=180

RAG_ENABLE_LLM_ANSWER_REVIEW=true
RAG_LLM_ANSWER_REVIEW_PROVIDER=openai_compatible
RAG_LLM_ANSWER_REVIEW_URL=
RAG_LLM_ANSWER_REVIEW_API_KEY=
RAG_LLM_ANSWER_REVIEW_MODEL=
RAG_LLM_ANSWER_REVIEW_TIMEOUT=180

RAG_ENABLE_LLM_REFLECTION=true
RAG_LLM_REFLECTION_PROVIDER=openai_compatible
RAG_LLM_REFLECTION_URL=
RAG_LLM_REFLECTION_API_KEY=
RAG_LLM_REFLECTION_MODEL=
RAG_LLM_REFLECTION_TIMEOUT=180

# Aliyun IQS
ALIYUN_IQS_API_KEY=
IQS_ENABLE_LLM_QUERY_REWRITE=false
IQS_ENABLE_HYDE=false

# Report quality controls
REPORT_QUALITY_MODE=strict
REPORT_PROGRESS_BAR=true
REPORT_REFORMATTER_SOURCE_APPENDIX=none
REPORT_CONTRACT_ENABLED=true
EVIDENCE_LEDGER_ENABLED=true
QUALITY_GATE_STATE_MACHINE_ENABLED=true
QUALITY_GATE_ENFORCE=false

